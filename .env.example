# Botboard configuration
PORT=3000
SESSION_SECRET=replace-with-long-random-value
SESSION_DIR=./.sessions
BOTS_CONFIG_PATH=./data/bots.json

# The same value must be set as BOT_API_TOKEN in each connected bot.
BOT_API_TOKEN=replace-with-long-random-value
MUSIC_BOT_URL=http://127.0.0.1:3001
SOUND_BOT_URL=http://127.0.0.1:3002

# Discord login. Keep DEV_AUTH_BYPASS=false for real Discord authentication.
COOKIE_SECURE=false
DEV_AUTH_BYPASS=false
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback
ALLOWED_USER_IDS=

# Container restart buttons. Leave disabled for local runs.
DOCKER_RESTART_ENABLED=false
MUSIC_BOT_CONTAINER=newimusicbot
SOUND_BOT_CONTAINER=soundboard
DOCKER_SOCKET=/var/run/docker.sock
